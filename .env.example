# ============================================================
# APT Threat Hunting Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in actual values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# ============================================================

# ── Wazuh Manager ──
WAZUH_API_PASSWORD=SecretPassword1!
WAZUH_REGISTRATION_PASSWORD=AgentRegistrationPass!

# ── Platform Security ──
JWT_SECRET=change-this-to-a-random-64-char-string
MODEL_SIGNING_KEY=change-this-to-another-random-string

# ── MISP Threat Intelligence (optional) ──
MISP_API_KEY=your-misp-api-key-here
MISP_URL=https://misp.example.com

# ── Beem Africa SMS (optional — leave blank to disable the SMS channel) ──
# Sign up at https://login.beem.africa/, top up TZS credits, and create an
# API key + secret under Account → API Keys. The sender ID must be
# pre-registered by Beem (their support team). The platform also accepts
# BEEM_BASE_URL for staging endpoints; default is apisms.beem.africa.
BEEM_API_KEY=
BEEM_SECRET_KEY=
BEEM_SENDER_ID=APT-THP

# ── Local SMTP (optional — only if you also want email alongside SMS) ──
# Use an in-country relay (Postfix on the LAN, or your provider's submission
# port). Public-cloud relays like SendGrid would breach data-sovereignty.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ── Companion-app QR (optional override) ──
# Pre-set the URL the QR encodes for the phone. If unset, scripts/pair-up.sh
# auto-detects the laptop's LAN IP each time the api container starts.
# PUBLIC_HOST_URL=http://192.168.1.10:8000

# ── Platform Settings ──
LOG_LEVEL=INFO
CONFIG_DIR=config
DATA_DIR=data

# ── Auto-retrain scheduler (off by default) ──
# When RETRAIN_ENABLED=true, the api spawns a background task that retrains
# lateral_movement + dns_exfiltration on a configurable cadence. New
# versions are STAGED — they don't take effect until an admin promotes them
# from the dashboard (/dashboard/retrain). The interval + initial delay are
# also changeable at runtime from the same page.
RETRAIN_ENABLED=false
# Cycle cadence — 24 h default. The retrain pipeline is memory-heavy
# (xgboost + synthetic-data generator) and aggressively short intervals
# can OOM-kill the api container under tight memory limits. Tighten via the
# dashboard or this env var only when actively iterating on the models.
RETRAIN_INTERVAL_SECONDS=86400
# First-cycle delay after api start — 1 h default. Keeps the api responsive
# during cold boot and prevents the retrain process from competing with
# request-serving for RAM during the first minute of life. Set to 60 for
# the legacy "kick a cycle a minute after boot" behaviour.
RETRAIN_INITIAL_DELAY_SECONDS=3600
RETRAIN_BENIGN_WINDOW_HOURS=24
RETRAIN_LATERAL_ATTACKS_PER_DAY=10
RETRAIN_DNS_ATTACKS_PER_DAY=8
RETRAIN_NUM_BOOST_ROUND=200

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Foreground service that holds the SSE connection -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Re-arm the listener after a reboot so weekend pages don't go silent -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Android 13+ requires explicit grant for posting notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Vibrate on CRITICAL detections -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- QR scanner -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false"/>
    <!-- Biometric gate on app open + sensitive actions -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <!--
      Coarse location captured ONCE during enrolment so the admin's Paired
      Phones page can show where a device was paired. The app never tracks
      location after enrolment; declining the permission is fine — the
      pairing still completes without it.
    -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-feature android:name="android.hardware.location" android:required="false"/>
    <uses-feature android:name="android.hardware.location.network" android:required="false"/>

    <application
        android:label="@string/app_name"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.AptThp"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep-link from native notification: apt-thp://alert/<id> -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="apt-thp" android:host="alert" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.NotificationListener"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <!--
          BOOT_COMPLETED is a protected broadcast — only the system can fire it,
          so the receiver does not need to be exported.
        -->
        <receiver
            android:name=".service.BootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".service.AckReceiver"
            android:exported="false" />

        <receiver
            android:name=".service.QuickReplyReceiver"
            android:exported="false" />
    </application>
</manifest>
